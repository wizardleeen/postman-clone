{
  "name": "postman-clone",
  "version": "1.0.0",
  "description": "Desktop HTTP client tool similar to Postman",
  "type": "module",
  "main": "dist/electron/main.js",
  "homepage": "./",
  "scripts": {
    "dev": "concurrently \"npm run dev:vue\" \"npm run dev:electron\"",
    "dev:vue": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build": "vite build",
    "build:vue": "vite build --outDir dist",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build:desktop": "npm run build:vue && npm run build:electron",
    "electron": "electron .",
    "dist": "npm run build:desktop && electron-builder",
    "preview": "vite preview --host 0.0.0.0 --port 3000",
    "start": "npm run preview"
  },
  "keywords": ["http", "client", "postman", "electron", "vue"],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/state": "^6.4.0",
    "@codemirror/view": "^6.21.3",
    "axios": "^1.6.2",
    "codemirror": "^6.0.1",
    "pinia": "^2.1.7",
    "vue": "^3.3.8",
    "vue-router": "^4.2.5",
    "vite": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@vitejs/plugin-vue": "^4.5.0",
    "concurrently": "^8.2.2",
    "electron": "^27.1.3",
    "electron-builder": "^24.6.4",
    "typescript": "^5.3.2",
    "vue-tsc": "^1.8.22",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.example.postmanclone",
    "productName": "HTTP Client",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}